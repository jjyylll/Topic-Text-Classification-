        "# Object oriented program\n",
        "#TEXT PROCESSING PROGRAM\n",
        "# TEAM OMEGA (Abroan,Joyal)\n",
        "import string\n",
        "from collections import Counter\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "class TextAnalyzer:\n",
        "\n",
        "\n",
        "  def __init__(self,lines):\n",
        "      self.lines = lines\n",
        "      self.full_text = self._join_lines()\n",
        "      self.clean_text = self._clear_punctuation()\n",
        "      self.words = self.clean_text.lower().split()\n",
        "      self.word_count = Counter(self.words)\n",
        "\n",
        "  def _join_lines(self):\n",
        "      return \"\".join(self.lines)\n",
        "\n",
        "  def _clear_punctuation(self):\n",
        "      cleaned_text_parts = []\n",
        "      for ch in self.full_text:\n",
        "          if ch not in string.punctuation:\n",
        "            cleaned_text_parts.append(ch)\n",
        "      return \"\".join(cleaned_text_parts)\n",
        "\n",
        "  def count_characters(self):\n",
        "   with_spaces = len(self.full_text)\n",
        "   without_spaces = len(self.full_text.replace(\" \", \"\"))\n",
        "   return with_spaces , without_spaces\n",
        "\n",
        "  def count_words(self):\n",
        "    return len(self.words)\n",
        "\n",
        "  def count_special_words(self):\n",
        "    return len(set(self.words))\n",
        "\n",
        "  def count_sentence(self):\n",
        "        return sum(self.full_text.count(ch) for ch in \".!?\")\n",
        "\n",
        "\n",
        "  def count_paragraphs(self):\n",
        "      paragraphs = self.full_text.split(\"\\n\\n\")\n",
        "      return len([p for p in paragraphs if p.strip()])\n",
        "\n",
        "  def project_result(self):\n",
        "      characters_with_spaces, characters_without_spaces = self.count_characters()\n",
        "      total_words = self.count_words()\n",
        "      total_sentence = self.count_sentence()\n",
        "      total_paragraphs = self.count_paragraphs()\n",
        "\n",
        "      results = {\n",
        "        \"characters_with_spaces\": characters_with_spaces,\n",
        "        \"characters_without_spaces\": characters_without_spaces,\n",
        "        \"total_words\":total_words,\n",
        "        \"total_sentence\":total_sentence,\n",
        "        \"total_paragraphs\" : total_paragraphs\n",
        "\n",
        "      }\n",
        "\n",
        "      print(\"TEXT ANALYSIS RESULT\")\n",
        "      for key, value in results.items():\n",
        "        print(f\"{key.replace('_',' ').title()}:{value}\")\n",
        "\n",
        "\n",
        "      print(\"\\nTop 10 most common words\")\n",
        "      for words,count in self.word_count.most_common(10):\n",
        "         print(f\"{words} : {count}\")\n",
        "\n",
        "  # Moved inside the class\n",
        "  def plot_summary(self):\n",
        "      labels = [\"words\",\"sentences\",\"paragraphs\",\"special words\"]\n",
        "      values = [\n",
        "          self.count_words(),\n",
        "          self.count_sentence(),\n",
        "          self.count_paragraphs(),\n",
        "          len(self.word_count)\n",
        "\n",
        "      ]\n",
        "      plt.bar(labels,values, color= \"black\")\n",
        "      plt.title(\"Text Analysis Summary\")\n",
        "      plt.show()\n",
        "\n",
        "def get_input_text():\n",
        "  choice = input(\"Enter A to type text,Enter Bto load from file: \")\n",
        "\n",
        "  if choice == \"A\":\n",
        "    text = input(\"\\nEnter your text:\\n\")\n",
        "    return [text]\n",
        "\n",
        "  elif choice == \"B\":\n",
        "    filename = input(\"Enter filename (.txt): \")\n",
        "    with open(filename, \"r\") as file:\n",
        "      return file.readlines()\n",
        "\n",
        "  else:\n",
        "    print(\"Invalid choice!\")\n",
        "    return []\n",
        "\n",
        "lines = get_input_text()\n",
        "if  lines:\n",
        "   analysis =TextAnalyzer(lines)\n",
        "   analysis.project_result()\n",
        "   analysis.plot_summary()"
